<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Earth Steward — Location</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

/* iPhone shell */
body {
  background: #1a1a1a;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  font-family: -apple-system, 'SF Pro Display', sans-serif;
}

.phone {
  width: 390px;
  height: 844px;
  background: #0A0F0C;
  border-radius: 54px;
  border: 6px solid #2a2a2a;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
  box-shadow: 0 40px 80px rgba(0,0,0,0.8), inset 0 0 0 1px #333;
}

/* Status bar */
.status-bar {
  height: 54px;
  background: #0A0F0C;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 28px 8px;
  flex-shrink: 0;
  z-index: 100;
}
.status-time { font-size: 15px; font-weight: 600; color: #E8F5EE; }
.status-icons { display: flex; align-items: center; gap: 6px; }
.status-icons svg { width: 16px; height: 16px; fill: #E8F5EE; }

/* Header */
.header {
  background: #0A0F0C;
  padding: 8px 20px 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
  z-index: 100;
}
.header-logo { display: flex; align-items: center; gap: 8px; }
.header-icon { width: 28px; height: 28px; background: #1A2B1E; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
.header-title { font-size: 17px; font-weight: 600; color: #E8F5EE; }
.header-subtitle { font-size: 11px; color: #4A6B54; margin-top: 1px; }
.gps-badge { background: #1A2B1E; border: 1px solid #2D7A4F; border-radius: 20px; padding: 4px 10px; display: flex; align-items: center; gap: 5px; font-size: 11px; color: #2D7A4F; font-weight: 500; }
.gps-dot { width: 6px; height: 6px; border-radius: 50%; background: #2D7A4F; animation: pulse 1.5s infinite; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

/* Warning banner */
.warning-banner {
  background: #E5FF2C;
  padding: 8px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
  z-index: 100;
  cursor: pointer;
}
.warning-text { font-size: 12px; font-weight: 600; color: #0D2B1C; flex: 1; line-height: 1.3; }
.warning-arrow { font-size: 14px; color: #0D2B1C; }

/* Map */
#map {
  flex: 1;
  z-index: 1;
}

/* Parcel card */
.parcel-card {
  background: #111A13;
  border-top: 1px solid #1A2B1E;
  padding: 14px 20px 10px;
  flex-shrink: 0;
  z-index: 100;
}
.parcel-handle { width: 36px; height: 4px; background: #1A2B1E; border-radius: 2px; margin: 0 auto 12px; }
.parcel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.parcel-id { font-size: 13px; font-weight: 700; color: #E8F5EE; }
.parcel-badge { background: #1A2B1E; border: 1px solid #2D7A4F; border-radius: 4px; padding: 2px 8px; font-size: 10px; color: #2D7A4F; font-weight: 600; }
.parcel-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; margin-bottom: 12px; }
.parcel-item { }
.parcel-label { font-size: 10px; color: #4A6B54; margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.3px; }
.parcel-value { font-size: 13px; font-weight: 600; color: #E8F5EE; }
.parcel-zone { background: #1A2B1E; border-radius: 8px; padding: 8px 12px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.zone-text { font-size: 12px; color: #8FAF99; }
.zone-name { font-size: 12px; font-weight: 600; color: #2D7A4F; }
.continue-btn { background: #2D7A4F; border: none; border-radius: 12px; width: 100%; padding: 13px; font-size: 15px; font-weight: 600; color: #E8F5EE; cursor: pointer; font-family: inherit; }
.continue-btn:active { background: #1A5235; }

/* Tab bar */
.tab-bar {
  background: #0A0F0C;
  border-top: 1px solid #1A2B1E;
  height: 82px;
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  padding: 10px 0 0;
  flex-shrink: 0;
  z-index: 100;
}
.tab { display: flex; flex-direction: column; align-items: center; gap: 4px; cursor: pointer; padding: 0 12px; }
.tab svg { width: 24px; height: 24px; }
.tab-label { font-size: 10px; color: #4A6B54; }
.tab.active .tab-label { color: #2D7A4F; }
.tab.active svg { stroke: #2D7A4F; }
.tab svg { stroke: #4A6B54; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }

/* Leaflet overrides for dark theme */
.leaflet-container { background: #0A0F0C !important; }
.leaflet-control-zoom { display: none; }
.leaflet-control-attribution { display: none; }
</style>
</head>
